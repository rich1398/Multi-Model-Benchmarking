# Occursus-Claude Environment Variables
# Copy to .env and fill in your API keys
# Note: API keys can also be set via the Settings UI in the app.

# Anthropic API (optional - for cloud model support)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (optional - for cloud model support)
# OPENAI_API_KEY=sk-...

# Google Gemini API (optional - for Gemini model support)
# GEMINI_API_KEY=AIza...

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
